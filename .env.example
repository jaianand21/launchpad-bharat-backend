# Copy this file to .env and fill in your values
# NEVER commit the actual .env file

PORT=5000

# Generate a random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# Google OAuth Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Frontend URL (change to your deployed URL in production)
FRONTEND_URL=http://localhost:5173

# Vonage SMS (formerly Nexmo) - Free Tier for OTPs
VONAGE_API_KEY=YOUR_VONAGE_API_KEY
VONAGE_API_SECRET=YOUR_VONAGE_API_SECRET

# Groq API Keys (Multi-key pool for high limits)
GROQ_API_KEY_pvt=gsk_your_private_groq_key_here
GROQ_API_KEY_eng=gsk_your_engineering_groq_key_here
GROQ_API_KEY_abhay=gsk_your_abhay_groq_key_here
GROQ_API_KEY_abhay_class=gsk_your_abhay_class_groq_key_here

# Gemini API Keys (Multi-key fallback pool)
GEMINI_API_pvt=AIzaSy_your_private_gemini_key_here
GEMINI_API_eng=AIzaSy_your_engineering_gemini_key_here
GEMINI_API_abhay=AIzaSy_your_abhay_gemini_key_here
GEMINI_API_abhay_class=AIzaSy_your_abhay_class_gemini_key_here

# Node environment
NODE_ENV=development

# SMTP Email Configuration (Brevo/SendGrid free tier recommended)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_login_email@example.com
SMTP_PASS=your_smtp_master_password
SMTP_FROM="Launchpad Bharat" <noreply@launchpadbharat.com>
